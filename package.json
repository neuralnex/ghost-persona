{
  "name": "ghost-persona",
  "version": "1.0.1",
  "description": "Local-first encrypted workspace memory for IDE agents.",
  "main": "./dist/extension/src/extension.js",
  "bin": {
    "ghost": "./dist/bin/ghost.js"
  },
  "publisher": "meru",
  "type": "module",
  "engines": {
    "vscode": "^1.120.0"
  },

  "activationEvents": [
    "onCommand:ghostPersona.lockWalletAddress",
    "onCommand:ghostPersona.connectStoryGlobalWallet",
    "onCommand:ghostPersona.getContextMarkdown",
    "onCommand:ghostPersona.getInjectedChatPipeline",
    "onCommand:ghostPersona.appendDynamicPrompt",
    "onCommand:ghostPersona.clearSessionLogs",
    "onCommand:ghostPersona.setPrivateKey",
    "onView:ghostContextView",
    "onUri"
  ],
  
  "categories": [
    "AI",
    "Programming Languages",
    "Chat"
  ],
  "scripts": {
    "compile": "esbuild ./extension/src/extension.ts --bundle --outfile=dist/extension/src/extension.js --external:vscode --packages=external --format=esm --platform=node",
    "build": "tsc && npm run compile",
    "test": "npm run build",
    "test:injection": "tsx test-injection.ts",
    "test:offline": "tsx test-offline.ts",
    "test:pipeline": "tsx test-pipeline.ts",
    "ghost": "tsx bin/ghost.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neuralnex/ghost-persona.git"
  },
  "keywords": [
    "ai",
    "vscode",
    "story-protocol",
    "cdr",
    "workspace-memory",
    "encrypted-context"
  ],
  "author": "meru",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/neuralnex/ghost-persona/issues"
  },
  "homepage": "https://github.com/neuralnex/ghost-persona#readme",
  "dependencies": {
    "@piplabs/cdr-sdk": "^0.2.1",
    "@story-protocol/core-sdk": "^1.4.4",
    "@story-protocol/global-wallet": "^0.0.3",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.5",
    "viem": "^2.51.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "configuration": {
      "title": "Ghost Persona",
      "properties": {
        "ghostPersona.mockMode": {
          "type": "boolean",
          "default": true,
          "description": "Run the workspace identity lifecycle offline using mock threshold parameters."
        },
        "ghostPersona.walletAddress": {
          "type": "string",
          "default": "",
          "markdownDescription": "Public EVM wallet address verified through Story Global Wallet or manually associated with this workspace. Private keys are never stored by Ghost Persona."
        },
        "ghostPersona.rpcUrl": {
          "type": "string",
          "default": "https://aeneid.storyrpc.io",
          "description": "RPC endpoint used when live CDR mode is enabled."
        },
        "ghostPersona.cdrApiUrl": {
          "type": "string",
          "default": "https://staging-api.storyprotocol.net/api/v4",
          "description": "CDR API endpoint used when live CDR mode is enabled."
        },
        "ghostPersona.globalWalletUrl": {
          "type": "string",
          "default": "https://companion-seven.vercel.app",
          "markdownDescription": "URL of a Story Global Wallet companion app. The app should import `@story-protocol/global-wallet/story`, sign the supplied nonce, and redirect to the supplied callback URI."
        },
        "ghostPersona.watcherDebounce": {
          "type": "number",
          "default": 3000,
          "description": "The debounce period in milliseconds before changes are securely synchronized to the workspace vault."
        }
      }
    },
    "commands": [
      {
        "command": "ghostPersona.lockWalletAddress",
        "title": "Ghost Persona: Lock Wallet Address"
      },
      {
        "command": "ghostPersona.connectStoryGlobalWallet",
        "title": "Ghost Persona: Connect Story Global Wallet"
      },
      {
        "command": "ghostPersona.getContextMarkdown",
        "title": "Ghost Persona: Get Context Markdown"
      },
      {
        "command": "ghostPersona.getInjectedChatPipeline",
        "title": "Ghost Persona: Get Injected Chat Pipeline"
      },
      {
        "command": "ghostPersona.appendDynamicPrompt",
        "title": "Ghost Persona: Append Dynamic Prompt"
      },
      {
        "command": "ghostPersona.clearSessionLogs",
        "title": "Ghost Persona: Clear Session Logs"
      },
      {
        "command": "ghostPersona.setPrivateKey",
        "title": "Ghost Persona: Set Transaction Signing Private Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ghost-persona-sidebar",
          "title": "Ghost Persona",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "ghost-persona-sidebar": [
        {
          "id": "ghostContextView",
          "name": "Sovereign Context Engine",
          "type": "webview",
          "icon": "$(lock)"
        }
      ]
    }
  }
}