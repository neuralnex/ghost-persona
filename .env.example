# Ghost Persona environment template
#
# Copy this file to .env for local development only. Never commit real secrets.

# Story Aeneid RPC endpoint.
STORY_RPC_URL=https://aeneid.storyrpc.io

# Story CDR API endpoint for the active testnet/runtime.
STORY_CDR_API_URL=

# Development/testnet software signer only.
# Production user identity should use Story Global Wallet signature callbacks.
GHOST_SOFTWARE_PRIVATE_KEY=

# Optional deployed Story Global Wallet companion app.
GHOST_GLOBAL_WALLET_URL=https://<your-story-wallet-companion>/connect

# Optional marketplace publishing metadata.
GHOST_MARKETPLACE_METADATA_URI=ipfs://<metadata-cid>
